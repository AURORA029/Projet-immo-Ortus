---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('actualites');
const articlesTries = articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Le Hack "Éditorial" : On isole le tout dernier article publié
const featuredArticle = articlesTries[0];
const regularArticles = articlesTries.slice(1);
---

<MainLayout 
    title="Insights & Expertise | ORTUS Immobilier" 
    description="Analyses de marché, tendances et conseils stratégiques pour sécuriser votre patrimoine d'exception à Madagascar."
>
    <header class="hero" style="height: 40vh; min-height: 300px; background: linear-gradient(rgba(2,6,16,0.7), rgba(2,6,16,0.7)), url('/Projet-immo-Ortus/assets/img/hero-bg.jpg') center/cover no-repeat;">
        <div class="container hero-content" style="display: flex; flex-direction: column; height: 100%; align-items: center; justify-content: center; text-align: center;">
            <h1 style="font-family: 'Playfair Display', serif; font-size: 3.5rem; color: #D4AF37; text-transform: uppercase; letter-spacing: 2px;">Insights & Expertise</h1>
            <p style="color: #ccc; font-family: 'Montserrat', sans-serif; font-size: 1.1rem; max-width: 600px; margin: 10px auto 0 auto;">Décrypter le marché malgache pour sécuriser vos investissements.</p>
        </div>
    </header>

    <section class="section-padding" style="background-color: #020610;">
        <div class="container">

            {featuredArticle && (
                <div style="margin-bottom: 80px;">
                    <div style="display: flex; flex-wrap: wrap; background: #050912; border: 1px solid rgba(212, 175, 55, 0.2); border-radius: 12px; overflow: hidden; align-items: stretch; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                        <div style="flex: 1; min-width: 300px; min-height: 400px; position: relative;">
                          <img src={featuredArticle.data.image} alt={featuredArticle.data.titre} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
                        </div>
                        <div style="flex: 1; padding: 50px; min-width: 300px; display: flex; flex-direction: column; justify-content: center;">
                            <span style="color: #D4AF37; font-family: 'Montserrat', sans-serif; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 3px;">À la Une • {featuredArticle.data.date.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}</span>
                            <h2 style="font-family: 'Playfair Display', serif; font-size: 2.5rem; margin: 20px 0; line-height: 1.2;">
                                <a href={`/Projet-immo-Ortus/actualites/${featuredArticle.slug}`} style="color: white; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#D4AF37'" onmouseout="this.style.color='white'">{featuredArticle.data.titre}</a>
                            </h2>
                            <p style="color: #aaa; font-family: 'Montserrat', sans-serif; font-size: 1rem; line-height: 1.7; margin-bottom: 40px;">
                                {featuredArticle.data.extrait}
                            </p>
                            <div>
                                <a href={`/Projet-immo-Ortus/actualites/${featuredArticle.slug}`} style="display: inline-block; border-bottom: 2px solid #D4AF37; color: white; font-family: 'Montserrat', sans-serif; padding-bottom: 5px; text-decoration: none; font-weight: 700; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; transition: 0.3s;" onmouseover="this.style.color='#D4AF37'" onmouseout="this.style.color='white'">
                                    Lire l'analyse <i class="fas fa-arrow-right" style="margin-left: 8px; color: #D4AF37;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            )}

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px;">
                {regularArticles.map(article => (
                    <article class="property-card" style="background: #0a1120; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.3); transition: transform 0.3s ease, border-color 0.3s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.borderColor='rgba(212, 175, 55, 0.3)'" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.05)'">
                        {article.data.image && (
                            <a href={`/Projet-immo-Ortus/actualites/${article.slug}`} style="display: block; height: 240px; overflow: hidden; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <img src={article.data.image} alt={article.data.titre} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                            </a>
                        )}
                        <div style="padding: 25px;">
                            <div style="font-family: 'Montserrat', sans-serif; font-size: 0.75rem; color: #D4AF37; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px;">
                                {article.data.date.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                            </div>
                            <h3 style="font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 15px; line-height: 1.3;">
                                <a href={`/Projet-immo-Ortus/actualites/${article.slug}`} style="color: white; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#D4AF37'" onmouseout="this.style.color='white'">
                                    {article.data.titre}
                                </a>
                            </h3>
                            <p style="color: white !important; font-family: 'Montserrat', sans-serif; font-size: 0.95rem; line-height: 1.6; margin-bottom: 20px;">
                                    {article.data.extrait}
                            </p>
                            <a href={`/Projet-immo-Ortus/actualites/${article.slug}`} style="color: white; font-family: 'Montserrat', sans-serif; font-weight: 700; text-decoration: none; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s;" onmouseover="this.style.color='#D4AF37'" onmouseout="this.style.color='white'">
                                Lire l'article <i class="fas fa-arrow-right" style="margin-left: 5px; color: #D4AF37;"></i>
                            </a>
                        </div>
                    </article>
                ))}
            </div>

        </div>
    </section>
</MainLayout>