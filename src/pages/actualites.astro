---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('actualites');
const articlesTries = articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Le Hack "Éditorial" : On isole le tout dernier article publié
const featuredArticle = articlesTries[0];
const regularArticles = articlesTries.slice(1);
---

<MainLayout 
    title="Insights & Expertise | ORTUS Immobilier" 
    description="Analyses de marché, tendances et conseils stratégiques pour sécuriser votre patrimoine d'exception à Madagascar."
>
    <header class="hero" style="height: 50vh; background: linear-gradient(to bottom, rgba(2,6,16,0.3), rgba(2,6,16,1)), url('/Projet-immo-Ortus/assets/img/hero-bg.jpg') center/cover no-repeat;">
        <div class="container hero-content" style="text-align: center; padding-top: 120px;">
            <h1 style="color: #D4AF37; font-family: 'Playfair Display', serif; font-size: 3.5rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px;">Insights & Expertise</h1>
            <p style="color: #ccc; font-family: 'Montserrat', sans-serif; font-size: 1.1rem; max-width: 600px; margin: 0 auto;">Décrypter le marché malgache pour sécuriser vos investissements.</p>
        </div>
    </header>

    <section class="section-padding" style="background-color: #020610; color: white;">
        <div class="container">

            {featuredArticle && (
                <div style="margin-bottom: 80px;">
                    <div style="display: flex; flex-wrap: wrap; background: #050912; border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 4px; overflow: hidden; align-items: stretch;">
                        <div style="flex: 1; min-width: 300px; min-height: 400px; position: relative;">
                          <img src={featuredArticle.data.image} alt={featuredArticle.data.titre} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
                        </div>
                        <div style="flex: 1; padding: 50px; min-width: 300px; display: flex; flex-direction: column; justify-content: center;">
                            <span style="color: #D4AF37; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 3px;">À la Une • {featuredArticle.data.date.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}</span>
                            <h2 style="font-family: 'Playfair Display', serif; font-size: 2.5rem; margin: 20px 0; line-height: 1.2;">
                                <a href={`/Projet-immo-Ortus/actualites/${featuredArticle.slug}`} style="color: white; text-decoration: none;">{featuredArticle.data.titre}</a>
                            </h2>
                            <p style="color: #999; font-size: 1rem; line-height: 1.7; margin-bottom: 40px;">
                                {featuredArticle.data.extrait}
                            </p>
                            <div>
                                <a href={`/Projet-immo-Ortus/actualites/${featuredArticle.slug}`} style="display: inline-block; border-bottom: 1px solid #D4AF37; color: #D4AF37; padding-bottom: 5px; text-decoration: none; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; transition: 0.3s;">
                                    Lire l'analyse <i class="fas fa-arrow-right" style="margin-left: 8px;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            )}

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 50px;">
                {regularArticles.map(article => (
                    <article style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 30px;">
                        {article.data.image && (
                            <a href={`/Projet-immo-Ortus/actualites/${article.slug}`} style="display: block; height: 220px; border-radius: 4px; overflow: hidden; margin-bottom: 20px;">
                                <img src={article.data.image} alt={article.data.titre} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                            </a>
                        )}
                        <div style="font-size: 0.75rem; color: #666; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px;">
                            {article.data.date.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                        </div>
                        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 15px; line-height: 1.3;">
                            <a href={`/Projet-immo-Ortus/actualites/${article.slug}`} style="color: #ccc; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#D4AF37'" onmouseout="this.style.color='#ccc'">
                                {article.data.titre}
                            </a>
                        </h3>
                        <p style="color: #888; font-size: 0.9rem; line-height: 1.6;">
                            {article.data.extrait}
                        </p>
                    </article>
                ))}
            </div>

        </div>
    </section>
</MainLayout>