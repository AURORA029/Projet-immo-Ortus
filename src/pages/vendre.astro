---
// src/pages/vendre.astro
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout 
    title="Espace Propriétaires | Vendre ou Estimer - ORTUS Immobilier" 
    description="Confiez votre bien à ORTUS Immobilier. Estimation précise, valorisation visuelle (drone/photo) et accès à notre fichier d'investisseurs qualifiés."
>
    <script is:inline src="https://tally.so/widgets/embed.js"></script>

    <style>
        /* --- LOADER VALEUR (Graphique qui monte) --- */
        .loader-container {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            z-index: 0;
        }

        .graph-loader {
            display: flex;
            align-items: flex-end;
            gap: 8px;
            height: 40px;
        }

        .bar {
            width: 8px;
            background-color: #D4AF37;
            animation: grow 1.5s infinite ease-in-out;
            opacity: 0.8;
        }

        .bar:nth-child(1) { height: 40%; animation-delay: -0.3s; }
        .bar:nth-child(2) { height: 100%; animation-delay: -0.15s; }
        .bar:nth-child(3) { height: 70%; animation-delay: 0s; }

        .loader-text {
            margin-top: 15px;
            color: #D4AF37;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            animation: pulseText 2s infinite;
        }

        @keyframes grow {
            0%, 100% { transform: scaleY(1); opacity: 0.8; }
            50% { transform: scaleY(1.5); opacity: 1; box-shadow: 0 0 15px rgba(212, 175, 55, 0.4); }
        }

        @keyframes pulseText {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }

        /* Conteneur Iframe Relatif pour l'animation */
        .iframe-wrapper {
            position: relative;
            min-height: 600px;
            width: 100%;
            background: rgba(0,0,0,0.2);
            border-radius: 8px;
        }
        
        iframe {
            position: relative;
            z-index: 2;
            opacity: 0; 
            transition: opacity 0.5s ease-in-out;
        }
    </style>

    <div class="container section-padding">
        <div class="estimation-banner" style="background: rgba(26, 16, 60, 0.95); margin: 0 auto; max-width: 900px; display:block; padding-bottom: 20px;">
            
            <div style="text-align: center; max-width: 800px; margin: 0 auto 40px auto; padding: 20px;">
                <h2 style="color: #D4AF37; font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 20px;">
                    Pourquoi confier votre bien à ORTUS ?
                </h2>
                <p style="color: #ccc; margin-bottom: 30px;">
                    Vendre ou louer un bien d'exception demande une stratégie d'exception. Nous ne nous contentons pas de publier une annonce, nous créons le coup de cœur.
                </p>

                <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; text-align: left;">
                    
                    <div style="flex: 1; min-width: 250px; background: #1a1f2e; padding: 20px; border-radius: 8px; border: 1px solid #333;">
                        <h4 style="color: white; margin-top: 0;"><i class="fas fa-camera" style="color: #D4AF37; margin-right: 10px;"></i> Valorisation Visuelle</h4>
                        <p style="font-size: 0.9rem; color: #bbb; margin-bottom: 0;">Photos HDR, vidéos drone et mise en scène. Nous révélons tout le potentiel de votre propriété.</p>
                    </div>

                    <div style="flex: 1; min-width: 250px; background: #1a1f2e; padding: 20px; border-radius: 8px; border: 1px solid #333;">
                        <h4 style="color: white; margin-top: 0;"><i class="fas fa-user-secret" style="color: #D4AF37; margin-right: 10px;"></i> Discrétion Absolue</h4>
                        <p style="font-size: 0.9rem; color: #bbb; margin-bottom: 0;">Accès à notre fichier privé d'investisseurs qualifiés. Vendez sans publicité si vous le souhaitez.</p>
                    </div>

                    <div style="flex: 1; min-width: 250px; background: #1a1f2e; padding: 20px; border-radius: 8px; border: 1px solid #333;">
                        <h4 style="color: white; margin-top: 0;"><i class="fas fa-chart-line" style="color: #D4AF37; margin-right: 10px;"></i> Expertise Juste</h4>
                        <p style="font-size: 0.9rem; color: #bbb; margin-bottom: 0;">Une analyse précise du marché (Prix de vente ou Loyer) pour valoriser votre actif au mieux.</p>
                    </div>

                </div>
            </div>

            <h1 style="color:#c5a065; text-align:center; margin-bottom:20px; font-family: 'Playfair Display', serif;">Estimer, Vendre ou Louer mon bien</h1>
            <p style="color:white; text-align:center; margin-bottom:40px; padding: 0 20px;">
                Propriétaire ? Remplissez ce formulaire et un expert Ortus vous contactera sous 24h pour définir la meilleure stratégie.
            </p>
            
            <div class="iframe-wrapper">
                <div class="loader-container" id="tally-loader">
                    <div class="graph-loader">
                        <div class="bar"></div>
                        <div class="bar"></div>
                        <div class="bar"></div>
                    </div>
                    <div class="loader-text">Chargement du dossier...</div>
                </div>

                <iframe 
                    src="https://tally.so/embed/Xx0NM4?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1" 
                    loading="lazy" 
                    width="100%" 
                    height="600" 
                    frameborder="0" 
                    marginheight="0" 
                    marginwidth="0" 
                    title="Dossier Propriétaire Ortus"
                    onload="document.getElementById('tally-loader').style.display='none'; this.style.opacity='1';"
                >
                </iframe>
            </div>
            
            <p style="text-align: center; font-size: 0.8rem; color: #aaa; margin-top: 20px; font-style: italic; max-width: 600px; margin-left: auto; margin-right: auto;">
                <span style="color: #D4AF37; font-weight: bold;">*</span> 
                Ces informations sont nécessaires pour assurer un traitement 
                <span style="color: #ffffff; font-weight: 500;">confidentiel et précis</span> 
                de votre demande par nos experts.
            </p>

        </div>
    </div>
    <script is:inline>
        // On écoute les messages venant de l'Iframe Tally
        window.addEventListener('message', (event) => {
            // Si le message indique que le formulaire est soumis
            if (event && event.data && typeof event.data === 'string' && event.data.includes('Tally.FormSubmitted')) {
                // On force la redirection vers la page merci avec le bon chemin
                window.location.href = '/Projet-immo-Ortus/merci';
            }
        });
    </script>
</MainLayout>