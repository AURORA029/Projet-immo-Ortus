---
import MainLayout from '../layouts/MainLayout.astro';
import { getProperties } from '../utils/googleSheets.js';

const allProperties = await getProperties();
const prestigeProperties = allProperties.filter(p => 
    p.gamme && p.gamme.toLowerCase().includes('prestige')
);
---

<MainLayout 
    title="Collection Prestige | ORTUS Immobilier" 
    description="Découvrez l'immobilier d'exception à Madagascar. Villas de maître, propriétés historiques et domaines privés."
>
    <style>
        .prestige-bg {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: linear-gradient(135deg, #050a14 25%, transparent 25%), 
                              linear-gradient(225deg, #050a14 25%, transparent 25%), 
                              linear-gradient(45deg, #050a14 25%, transparent 25%), 
                              linear-gradient(315deg, #050a14 25%, transparent 25%);
            background-position: 10px 0, 10px 0, 0 0, 0 0;
            background-size: 20px 20px;
            background-repeat: repeat;
            opacity: 0.4;
            z-index: -1;
            pointer-events: none;
        }

        .prestige-header { 
            text-align: center; 
            padding: 150px 20px 60px; 
            background: radial-gradient(circle at center, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
        }
        .prestige-title { 
            font-family: 'Playfair Display', serif; 
            font-size: 3.5rem; 
            color: #D4AF37; 
            margin-bottom: 20px; 
            text-shadow: 0 4px 10px rgba(0,0,0,0.5);
            letter-spacing: 2px;
        }
        .prestige-subtitle { 
            color: #ccc; 
            font-family: 'Montserrat', sans-serif;
            font-size: 1.1rem; 
            max-width: 600px; 
            margin: 0 auto; 
            line-height: 1.6; 
            font-weight: 300;
        }
        
        .royal-divider {
            display: flex; align-items: center; justify-content: center; gap: 15px; margin: 30px auto;
        }
        .royal-line { width: 60px; height: 1px; background: #D4AF37; opacity: 0.6; }
        .royal-icon { color: #D4AF37; font-size: 1.2rem; }

        .property-card {
            background-color: #FFFFFF !important; 
            border: 1px solid #ddd !important; 
            border-radius: 12px; 
            overflow: hidden; 
            margin-bottom: 40px; 
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); 
            transition: transform 0.3s ease;
        }
        .property-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(212, 175, 55, 0.2); }
        
        @keyframes pulse {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 5px rgba(255, 255, 255, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
        }

        @media (max-width: 768px) { .prestige-title { font-size: 2.5rem; } }
    </style>

    <div class="prestige-bg"></div>

    <header class="prestige-header">
        <h1 class="prestige-title">Collection Prestige</h1>
        <div class="royal-divider">
            <span class="royal-line"></span>
            <i class="fas fa-crown royal-icon"></i> <span class="royal-line"></span>
        </div>
        <p class="prestige-subtitle">
            Une sélection confidentielle de propriétés d'exception.<br>
            Luxe, volupté et art de vivre malgache.
        </p>
    </header>

    <section class="section-padding" style="min-height: 50vh;">
        <div class="container" style="max-width: 900px; margin: 0 auto;">
            
            {prestigeProperties.length === 0 ? (
                <div style="text-align: center; padding: 50px; background: rgba(0,0,0,0.5); border: 1px solid #333; border-radius: 8px;">
                    <i class="fas fa-gem" style="color: #D4AF37; font-size: 3rem; margin-bottom: 20px;"></i>
                    <h3 style="color: white; font-family: 'Playfair Display', serif;">La collection est en cours de mise à jour.</h3>
                    <p style="color: #888; font-family: 'Montserrat', sans-serif;">Contactez-nous pour nos offres Off-Market.</p>
                </div>
            ) : (
                <div class="properties-grid js-prestige-grid" style="display: grid; grid-template-columns: 1fr; gap: 50px;">
                    {prestigeProperties.map((p, index) => {
                        const categorieBien = (p.categorie || "").toLowerCase();
                        const typeAction = categorieBien.includes('loc') ? "LOCATION" : "VENTE";
                        const features = p.caracteristiques ? p.caracteristiques.replace(/\n/g, ',').split(',').map(f => f.trim()).filter(f => f).slice(0, 3) : [];
                        const fakeInteresse = [7, 12, 5, 9][index % 4] || 3;
                        const imgSrc = p.image && p.image.startsWith('http') ? p.image : `/${p.image || 'assets/img/hero-bg.jpg'}`;

                        return (
                            <div class="property-card js-property-card" style="display: none;">
                                
                                <div class="property-image" style="height:350px; position:relative; overflow:hidden;">
                                    
                                    <span style="position:absolute; top:15px; left:15px; background:#D4AF37; color:black; padding:6px 15px; font-weight:800; font-size:0.8rem; border-radius:4px; z-index:10; box-shadow: 0 2px 5px rgba(0,0,0,0.3); letter-spacing:1px;">PRESTIGE</span>
                                    
                                    <span style="position:absolute; top:15px; right:15px; background:#000; color:#fff !important; border:1px solid #D4AF37; padding:6px 15px; z-index:10; font-weight:700; font-size:0.8rem; border-radius:4px;">{typeAction}</span>
                                    
                                    <a href={`/biens/${p.id}`}>
                                        <img src={imgSrc} alt={p.titre} style="width:100%; height:100%; object-fit:cover; transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                                    </a>

                                    {typeAction === 'VENTE' && (
                                        <span style="position: absolute; bottom: 15px; right: 15px; background: #e63946; color: white; padding: 6px 15px; font-size: 0.85rem; border-radius: 20px; font-weight: bold; z-index: 10;">
                                            <i class="fas fa-circle" style="font-size: 0.5rem; margin-right: 5px; vertical-align: middle; animation: pulse 1.5s infinite;"></i> {fakeInteresse} intéressés
                                        </span>
                                    )}
                                </div>
                                
                                <div class="property-details" style="padding: 30px;">
                                    <h3 style="margin:0 0 10px 0;">
                                        <a href={`/biens/${p.id}`} style="text-decoration:none; color: #111 !important; font-family:'Playfair Display', serif; font-size:1.8rem; display:block;">{p.titre}</a>
                                    </h3>
                                    
                                    <p style="color:#666 !important; font-size:1rem; margin-bottom:20px; display:flex; align-items:center; font-family: 'Montserrat', sans-serif;">
                                        <i class="fas fa-map-marker-alt" style="color:#D4AF37 !important; margin-right:8px;"></i> {p.ville}
                                    </p>
                                    
                                    <div style="display:flex; gap:20px; margin-bottom:20px; padding-bottom:20px; border-bottom:1px solid #eee; color:#444; font-family: 'Montserrat', sans-serif; font-size:1.1rem;">
                                        <span title="Pièces"><i class="fas fa-door-open" style="color:#D4AF37; margin-right: 5px;"></i> {p.pieces || '?'} p.</span>
                                        <span title="Surface"><i class="fas fa-ruler-combined" style="color:#D4AF37; margin-right: 5px;"></i> {p.surface} m²</span>
                                    </div>
                                    
                                    <div style="color: #D4AF37; font-weight:800; font-size:2rem; margin-bottom:20px; font-family: 'Montserrat', sans-serif;" set:html={p.prix}></div>
                                    
                                    {features.length > 0 && (
                                        <ul style="list-style:none; padding:0; margin-bottom:30px; font-family: 'Montserrat', sans-serif;">
                                            {features.map(f => (
                                                <li style="color: #555; margin-bottom: 8px; display:flex; align-items:center; font-size:0.95rem;">
                                                    <i class="fas fa-check" style="color:#D4AF37; margin-right:10px; font-size:0.8rem;"></i> {f}
                                                </li>
                                            ))}
                                        </ul>
                                    )}
                                    
                                    <div style="display:flex; gap:15px;">
                                        <a href={`/biens/${p.id}`} style="flex:1; text-align:center; padding:15px; background:white; border:1px solid #111; color:#111; text-decoration:none; font-weight:bold; font-size:1rem; border-radius:4px; font-family: 'Montserrat', sans-serif; transition:0.3s;" onmouseover="this.style.background='#111'; this.style.color='white'" onmouseout="this.style.background='white'; this.style.color='#111'">Voir détails</a>
                                        <a href={`/biens/${p.id}#contact`} style="flex:1; text-align:center; padding:15px; background:#D4AF37; color:black; border:none; font-weight:bold; font-size:1rem; border-radius:4px; text-decoration:none; font-family: 'Montserrat', sans-serif; transition:0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">Contact</a>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            )}
            
            <div id="pagination-container" style="display:flex; justify-content:center; gap:10px; margin-top:50px; flex-wrap:wrap;"></div>
        </div>
    </section>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const ITEMS_PER_PAGE = 9;
            let currentPage = 1;
            const cards = Array.from(document.querySelectorAll('.js-property-card'));
            const paginationContainer = document.getElementById('pagination-container');

            if(cards.length === 0) return;

            function renderPage(page) {
                currentPage = page;
                cards.forEach(c => c.style.display = 'none');
                
                const start = (page - 1) * ITEMS_PER_PAGE;
                const end = start + ITEMS_PER_PAGE;
                
                cards.slice(start, end).forEach(c => {
                    c.style.display = 'flex';
                    c.style.animation = 'fadeUp 0.5s ease-out forwards';
                });

                buildPagination();
            }

            function buildPagination() {
                paginationContainer.innerHTML = '';
                const totalPages = Math.ceil(cards.length / ITEMS_PER_PAGE);
                if (totalPages <= 1) return;

                if (currentPage > 1) {
                    const btnPrev = document.createElement('button');
                    btnPrev.innerHTML = '<i class="fas fa-chevron-left"></i>';
                    btnPrev.style.cssText = "padding:10px 15px; background:#222; color:white; border:1px solid #333; cursor:pointer; margin:0 5px; border-radius: 4px;";
                    btnPrev.onclick = () => { renderPage(currentPage - 1); window.scrollTo({ top: 300, behavior: 'smooth' }); };
                    paginationContainer.appendChild(btnPrev);
                }

                for (let i = 1; i <= totalPages; i++) {
                    const btn = document.createElement('button');
                    btn.innerText = i;
                    btn.style.cssText = `padding:10px 15px; border:none; border-radius: 4px; font-weight:bold; margin:0 5px; cursor:pointer; background: ${i === currentPage ? '#D4AF37' : '#222'}; color: ${i === currentPage ? 'black' : 'white'}; border: ${i === currentPage ? 'none' : '1px solid #333'}`;
                    btn.onclick = () => { renderPage(i); window.scrollTo({ top: 300, behavior: 'smooth' }); };
                    paginationContainer.appendChild(btn);
                }

                if (currentPage < totalPages) {
                    const btnNext = document.createElement('button');
                    btnNext.innerHTML = '<i class="fas fa-chevron-right"></i>';
                    btnNext.style.cssText = "padding:10px 15px; background:#222; color:white; border:1px solid #333; cursor:pointer; margin:0 5px; border-radius: 4px;";
                    btnNext.onclick = () => { renderPage(currentPage + 1); window.scrollTo({ top: 300, behavior: 'smooth' }); };
                    paginationContainer.appendChild(btnNext);
                }
            }

            renderPage(1);
        });
    </script>
</MainLayout>